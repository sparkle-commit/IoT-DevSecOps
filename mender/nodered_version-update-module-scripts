#!/bin/sh

ACTION="$1"

case "$ACTION" in
    ArtifactInstall)
        TARGET_VERSION=$(cat "$PWD/files/version.txt" 2>/dev/null | tr -d '[:space:]' || echo "")
        if [ -z "$TARGET_VERSION" ]; then
            echo "ERROR: Cannot find target version!" >&2
            exit 1
        fi
        CURRENT_VERSION=$(node-red --version 2>/dev/null | awk '{print $2}' | sed 's/v//')
        echo "Current version: $CURRENT_VERSION"
        echo "ROLLBACK_VERSION=${CURRENT_VERSION}" > /var/lib/mender/nodered-rollback.env
        echo "Installing node-red@${TARGET_VERSION}..."
        npm install -g node-red@${TARGET_VERSION} || exit 1
        echo "Done!"
        ;;
    ArtifactCommit)
        systemctl restart node-red || exit 1
        sleep 5
        if ! systemctl is-active --quiet node-red; then
            echo "ERROR: node-red failed to start!" >&2
            exit 1
        fi
        echo "node-red running successfully!"
        ;;
    ArtifactRollback)
        if [ -f /var/lib/mender/nodered-rollback.env ]; then
            . /var/lib/mender/nodered-rollback.env
        else
            ROLLBACK_VERSION=$(npm list -g node-red --depth=0 2>/dev/null | grep node-red | grep -oP '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        fi
        if [ -z "$ROLLBACK_VERSION" ]; then
            echo "ERROR: Cannot determine rollback version!" >&2
            exit 1
        fi
        echo "Rolling back to node-red@${ROLLBACK_VERSION}..."
        npm install -g node-red@${ROLLBACK_VERSION} || exit 1
        systemctl restart node-red
        echo "Rollback complete to v${ROLLBACK_VERSION}!"
        ;;
    NeedsArtifactReboot)
        echo "No"
        ;;
    SupportsRollback)
        echo "Yes"
        ;;
    Cleanup)
        rm -f /var/lib/mender/nodered-rollback.env
        ;;
esac

exit 0
